HQ-SRV:
В Proxmox добавить к HQ-SRV два диска по 1 ГБ. Потом на HQ-SRV:
apt-get update && apt-get install -y mdadm
lsblk  # найти диски, обычно /dev/sdb и /dev/sdc
mdadm --create /dev/md0 --level=0 --raid-devices=2 /dev/sdb /dev/sdc
mdadm --detail --scan > /etc/mdadm.conf
fdisk /dev/md0  -> n -> p -> Enter -> Enter -> Enter -> w
mkfs.ext4 /dev/md0p1
mkdir -p /raid
mount /dev/md0p1 /raid
Быстрое автомонтирование через fstab:
echo "/dev/md0p1 /raid ext4 defaults 0 0" >> /etc/fstab
mount -a
df -h | grep raid

